# Copy this file to .env.local and adjust if your backend runs elsewhere.
#
# REQUIRED — no default and no fallback in code. If unset, API requests
# resolve against the frontend's own origin instead of the backend, which
# fails silently rather than erroring at build/start time.
# In production, point this at your deployed backend's public URL, e.g.
# https://api.your-app.example.com — never a localhost address.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
