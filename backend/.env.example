# Copy this file to .env and fill in real values. Never commit .env.
#
# REQUIRED (no default — the app fails fast at startup if either is
# missing or blank):
#   DATABASE_URL, OPENAI_API_KEY
# Everything else below has a safe default baked into the app and only
# needs to be set here if you want to override it.

# Application (has a default)
ENVIRONMENT=development
APP_NAME=AI Document Assistant

# PostgreSQL (REQUIRED — no default)
# If the database name contains spaces, do not wrap the value in quotes
# here; this file is parsed by python-dotenv, which treats everything
# after "=" as the literal value, unlike a bash "source".
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/Ai Document Assistant

# OpenAI (OPENAI_API_KEY is REQUIRED — no default; the model names below
# have defaults)
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Storage (has defaults)
CHROMA_PERSIST_DIR=storage/chroma
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_BYTES=20971520

# Chunking / retrieval (has defaults)
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
RETRIEVAL_TOP_K=5

# Chat (has a default)
CHAT_MESSAGE_MAX_LENGTH=4000

# CORS — comma-separated origins allowed to call this API from a browser
# (has a default; in production set this to your real frontend origin(s),
# e.g. https://your-app.example.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
